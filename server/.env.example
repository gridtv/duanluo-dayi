# 后端服务配置

# 服务端口
PORT=3000

# === 大模型 API 配置（三选一，取消注释你使用的） ===

# 通义千问（阿里云）
# 申请地址: https://dashscope.console.aliyun.com/
LLM_PROVIDER=qwen
QWEN_API_KEY=your_qwen_api_key_here
QWEN_MODEL=qwen-plus

