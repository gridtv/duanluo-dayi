<!--pages/result/result.wxml-->
<view class="container">
  <!-- 顶部导航 -->
  <view class="nav-bar">
    <view class="nav-back" bindtap="goBack">
      <text class="back-arrow">‹</text>
      <text>返回</text>
    </view>
    <text class="nav-title">总结结果</text>
    <view class="nav-action" bindtap="shareResult">
      <text>分享</text>
    </view>
  </view>

  <view wx:if="{{record}}">
    <!-- 来源信息 -->
    <view class="card source-card">
      <view class="source-header">
        <text class="source-icon">{{typeIcon}}</text>
        <view class="source-info">
          <text class="source-title">{{record.title}}</text>
          <view class="source-meta">
            <text class="tag">{{record.typeLabel}}</text>
            <text class="text-muted">{{record.createTime}}</text>
          </view>
        </view>
      </view>
      <view class="prompt-info" wx:if="{{record.prompt}}">
        <text class="text-muted">总结要求：{{record.prompt}}</text>
      </view>
    </view>

    <!-- 要点列表 -->
    <view class="card points-card" wx:if="{{record.keyPoints.length > 0}}">
      <view class="section-title">
        <text class="section-icon">🎯</text>
        <text>核心要点</text>
      </view>
      <view class="points-list">
        <view class="point-item" wx:for="{{record.keyPoints}}" wx:key="index">
          <view class="point-number">{{index + 1}}</view>
          <text class="point-text">{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 摘要 -->
    <view class="card summary-card">
      <view class="section-title">
        <text class="section-icon">📝</text>
        <text>内容摘要</text>
      </view>
      <view class="summary-content">
        <text>{{record.summary}}</text>
      </view>
    </view>

    <!-- 结论 -->
    <view class="card conclusion-card" wx:if="{{record.conclusion}}">
      <view class="section-title">
        <text class="section-icon">💎</text>
        <text>结论</text>
      </view>
      <view class="conclusion-content">
        <text>{{record.conclusion}}</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-bar">
      <button class="btn-secondary" bindtap="copyResult">
        复制结果
      </button>
      <button class="btn-primary action-primary" bindtap="newSummary">
        继续总结
      </button>
    </view>
  </view>

  <view class="bottom-spacer"></view>
</view>
