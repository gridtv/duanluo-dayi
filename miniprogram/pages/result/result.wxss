/* pages/result/result.wxss */

.container {
  padding-bottom: 40rpx;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 88rpx 32rpx 24rpx;
}

.nav-back {
  display: flex;
  align-items: center;
  color: #7C6EE7;
  font-size: 28rpx;
}

.back-arrow {
  font-size: 44rpx;
  margin-right: 4rpx;
  line-height: 1;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #374151;
}

.nav-action {
  color: #7C6EE7;
  font-size: 28rpx;
}

/* 来源卡片 */
.source-card {
  padding-bottom: 28rpx;
}

.source-header {
  display: flex;
  align-items: center;
}

.source-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.source-info {
  flex: 1;
  overflow: hidden;
}

.source-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #374151;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.source-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.prompt-info {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(124, 110, 231, 0.08);
}

/* 要点卡片 */
.section-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 24rpx;
}

.section-icon {
  margin-right: 12rpx;
  font-size: 32rpx;
}

.points-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.point-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, rgba(124, 110, 231, 0.04), rgba(196, 181, 253, 0.06));
  border-radius: 16rpx;
}

.point-number {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #7C6EE7, #A78BFA);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
  margin-top: 2rpx;
}

.point-text {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.7;
  color: #4B5563;
}

/* 摘要卡片 */
.summary-content {
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(124, 110, 231, 0.03), rgba(232, 244, 253, 0.3));
  border-radius: 16rpx;
  border-left: 6rpx solid;
  border-image: linear-gradient(180deg, #7C6EE7, #A78BFA) 1;
}

.summary-content text {
  font-size: 28rpx;
  line-height: 1.8;
  color: #4B5563;
}

/* 结论卡片 */
.conclusion-content {
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(253, 240, 245, 0.5), rgba(124, 110, 231, 0.04));
  border-radius: 16rpx;
}

.conclusion-content text {
  font-size: 28rpx;
  line-height: 1.8;
  color: #374151;
  font-weight: 500;
}

/* 操作栏 */
.action-bar {
  display: flex;
  gap: 24rpx;
  padding: 32rpx;
}

.action-bar .btn-secondary {
  flex: 1;
  text-align: center;
}

.action-primary {
  flex: 1;
  padding: 20rpx 0;
  font-size: 28rpx;
}

.bottom-spacer {
  height: 40rpx;
}
