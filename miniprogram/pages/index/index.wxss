/* pages/index/index.wxss */

.container {
  padding-bottom: 40rpx;
}

/* ===== 顶部区域 ===== */
.header {
  position: relative;
  padding: 60rpx 40rpx 48rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: -40%;
  left: -20%;
  width: 140%;
  height: 200%;
  background: radial-gradient(ellipse at 30% 20%, rgba(124, 110, 231, 0.15) 0%, transparent 60%),
              radial-gradient(ellipse at 80% 60%, rgba(167, 139, 250, 0.1) 0%, transparent 50%);
  z-index: 0;
}

.header-content {
  position: relative;
  z-index: 1;
}

.app-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #7C6EE7, #A78BFA);
  -webkit-background-clip: text;
  color: transparent;
  margin-bottom: 12rpx;
}

.app-subtitle {
  display: block;
  font-size: 26rpx;
  color: #9CA3AF;
}

/* ===== 上传卡片 ===== */
.section-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 24rpx;
}

.section-icon {
  margin-right: 12rpx;
  font-size: 32rpx;
}

.upload-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 56rpx 32rpx;
  border: 3rpx dashed rgba(124, 110, 231, 0.3);
  border-radius: 20rpx;
  background: linear-gradient(135deg, rgba(124, 110, 231, 0.03), rgba(167, 139, 250, 0.05));
  transition: all 0.3s;
}

.upload-area:active {
  background: linear-gradient(135deg, rgba(124, 110, 231, 0.08), rgba(167, 139, 250, 0.1));
}

.upload-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #7C6EE7, #A78BFA);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(124, 110, 231, 0.25);
}

.upload-icon {
  font-size: 44rpx;
  color: #FFFFFF;
  font-weight: 300;
  line-height: 1;
}

.upload-text {
  font-size: 30rpx;
  color: #7C6EE7;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.upload-hint {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* 快捷选择 */
.quick-actions {
  display: flex;
  justify-content: space-around;
  margin-top: 28rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid rgba(124, 110, 231, 0.08);
}

.quick-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
}

.quick-btn:active {
  background: rgba(124, 110, 231, 0.06);
}

.quick-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.quick-btn text:last-child {
  font-size: 22rpx;
  color: #6B7280;
}

/* 文件信息 */
.file-info {
  display: flex;
  align-items: center;
  padding: 28rpx;
  background: linear-gradient(135deg, rgba(124, 110, 231, 0.05), rgba(196, 181, 253, 0.08));
  border-radius: 16rpx;
}

.file-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.file-icon {
  font-size: 36rpx;
}

.file-detail {
  flex: 1;
  overflow: hidden;
}

.file-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #374151;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.file-meta {
  display: flex;
  align-items: center;
}

.file-remove {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: rgba(239, 68, 68, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.file-remove text {
  color: #EF4444;
  font-size: 24rpx;
}

/* ===== 文本输入卡片 ===== */
.text-input {
  width: 100%;
  min-height: 160rpx;
  max-height: 400rpx;
  padding: 24rpx;
  background: rgba(124, 110, 231, 0.03);
  border: 2rpx solid rgba(124, 110, 231, 0.1);
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #374151;
  box-sizing: border-box;
}

.text-placeholder {
  color: #D1D5DB;
}

.text-counter {
  text-align: right;
  margin-top: 12rpx;
}

/* ===== 提示词卡片 ===== */
.optional-tag {
  margin-left: 8rpx;
  font-weight: 400;
}

.preset-prompts {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.preset-tag {
  display: inline-block;
  padding: 10rpx 24rpx;
  background: rgba(124, 110, 231, 0.06);
  border: 2rpx solid rgba(124, 110, 231, 0.12);
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #6B7280;
  transition: all 0.2s;
}

.preset-tag:active,
.preset-active {
  background: linear-gradient(135deg, rgba(124, 110, 231, 0.12), rgba(167, 139, 250, 0.15));
  border-color: rgba(124, 110, 231, 0.3);
  color: #7C6EE7;
}

.prompt-input {
  width: 100%;
  min-height: 100rpx;
  padding: 24rpx;
  background: rgba(124, 110, 231, 0.03);
  border: 2rpx solid rgba(124, 110, 231, 0.1);
  border-radius: 16rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #374151;
  box-sizing: border-box;
}

/* ===== 提交按钮 ===== */
.submit-area {
  padding: 32rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
}

.loading-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top: 4rpx solid #FFFFFF;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-right: 16rpx;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.bottom-spacer {
  height: 40rpx;
}
