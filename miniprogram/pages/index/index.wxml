<!--pages/index/index.wxml-->
<view class="container">
  <!-- 顶部欢迎区域 -->
  <view class="header">
    <view class="header-bg"></view>
    <view class="header-content">
      <text class="app-title">段落大意之凝聚</text>
      <text class="app-subtitle">上传文件，智能提炼要点与结论</text>
    </view>
  </view>

  <!-- 文件上传区域 -->
  <view class="card upload-card">
    <view class="section-title">
      <text class="section-icon">📎</text>
      <text>选择文件</text>
    </view>

    <!-- 未选择文件时显示上传区 -->
    <view class="upload-area" wx:if="{{!selectedFile}}" bindtap="chooseFile">
      <view class="upload-icon-wrapper">
        <text class="upload-icon">+</text>
      </view>
      <text class="upload-text">点击上传文件</text>
      <text class="upload-hint">支持文档 / 图片</text>
    </view>

    <!-- 已选择文件时显示文件信息 -->
    <view class="file-info" wx:if="{{selectedFile}}">
      <view class="file-icon-wrapper">
        <text class="file-icon">{{fileIcon}}</text>
      </view>
      <view class="file-detail">
        <text class="file-name">{{selectedFile.name}}</text>
        <view class="file-meta">
          <text class="tag">{{fileTypeLabel}}</text>
          <text class="text-muted">{{fileSize}}</text>
        </view>
      </view>
      <view class="file-remove" bindtap="removeFile">
        <text>✕</text>
      </view>
    </view>

    <!-- 快捷选择按钮 -->
    <view class="quick-actions" wx:if="{{!selectedFile}}">
      <view class="quick-btn" bindtap="chooseImage">
        <text class="quick-icon">🖼️</text>
        <text>图片</text>
      </view>
      <view class="quick-btn" bindtap="chooseDocument">
        <text class="quick-icon">📄</text>
        <text>文档</text>
      </view>
    </view>
  </view>

  <!-- 或者直接输入文本 -->
  <view class="card text-card">
    <view class="section-title">
      <text class="section-icon">✏️</text>
      <text>或直接粘贴文本</text>
    </view>
    <textarea
      class="text-input"
      placeholder="在此粘贴需要总结的文字内容..."
      placeholder-class="text-placeholder"
      value="{{inputText}}"
      bindinput="onTextInput"
      maxlength="10000"
      auto-height
    ></textarea>
    <view class="text-counter" wx:if="{{inputText}}">
      <text class="text-muted">{{inputText.length}} / 10000</text>
    </view>
  </view>

  <!-- 提示词设置 -->
  <view class="card prompt-card">
    <view class="section-title">
      <text class="section-icon">💡</text>
      <text>总结要求</text>
      <text class="text-muted optional-tag">（可选）</text>
    </view>

    <!-- 预设提示词 -->
    <view class="preset-prompts">
      <view
        class="preset-tag {{activePreset === index ? 'preset-active' : ''}}"
        wx:for="{{presetPrompts}}"
        wx:key="index"
        bindtap="selectPreset"
        data-index="{{index}}"
      >
        {{item.label}}
      </view>
    </view>

    <textarea
      class="prompt-input"
      placeholder="输入你的具体要求，例如：请用3个要点总结核心观点..."
      placeholder-class="text-placeholder"
      value="{{promptText}}"
      bindinput="onPromptInput"
      maxlength="500"
      auto-height
    ></textarea>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-area">
    <button
      class="btn-primary submit-btn"
      bindtap="startSummarize"
      disabled="{{!canSubmit || isLoading}}"
    >
      <text wx:if="{{!isLoading}}">开始总结</text>
      <view class="loading-wrapper" wx:if="{{isLoading}}">
        <view class="loading-spinner"></view>
        <text>正在分析中...</text>
      </view>
    </button>
  </view>

  <!-- 底部留白 -->
  <view class="bottom-spacer"></view>
</view>
