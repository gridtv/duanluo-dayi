<!--pages/history/history.wxml-->
<view class="container">
  <!-- 顶部标题 -->
  <view class="page-header">
    <text class="page-title">历史记录</text>
    <view class="clear-btn" bindtap="clearAll" wx:if="{{historyList.length > 0}}">
      <text>清空</text>
    </view>
  </view>

  <!-- 有历史记录 -->
  <view wx:if="{{historyList.length > 0}}">
    <view
      class="card history-item"
      wx:for="{{historyList}}"
      wx:key="id"
      bindtap="viewDetail"
      data-id="{{item.id}}"
    >
      <view class="item-header">
        <text class="item-icon">{{item.icon}}</text>
        <view class="item-info">
          <text class="item-title">{{item.title}}</text>
          <view class="item-meta">
            <text class="tag">{{item.typeLabel}}</text>
            <text class="text-muted">{{item.createTime}}</text>
          </view>
        </view>
      </view>
      <view class="item-preview" wx:if="{{item.summary}}">
        <text>{{item.summaryPreview}}</text>
      </view>
      <view class="item-actions">
        <view class="item-action-btn" catchtap="deleteItem" data-id="{{item.id}}">
          <text class="text-muted">删除</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 无历史记录 -->
  <view class="empty-state" wx:if="{{historyList.length === 0}}">
    <view class="empty-icon-wrapper">
      <text class="empty-icon">📋</text>
    </view>
    <text class="empty-title">还没有总结记录</text>
    <text class="empty-desc">上传文件或粘贴文本，开始你的第一次总结吧</text>
    <button class="btn-primary empty-btn" bindtap="goHome">去总结</button>
  </view>

  <view class="bottom-spacer"></view>
</view>
