/* ========== 全局样式 ========== */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC',
    'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  background: linear-gradient(160deg, #F5F0FF 0%, #E8F4FD 50%, #FDF0F5 100%);
  min-height: 100vh;
  color: #333333;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 柔和卡片风格 */
.card {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 36rpx;
  margin: 24rpx 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(124, 110, 231, 0.08);
}

/* 渐变按钮 */
.btn-primary {
  background: linear-gradient(135deg, #7C6EE7 0%, #A78BFA 50%, #C4B5FD 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 48rpx;
  padding: 24rpx 64rpx;
  font-size: 32rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  box-shadow: 0 8rpx 24rpx rgba(124, 110, 231, 0.3);
}

.btn-primary::after {
  border: none;
}

.btn-primary[disabled] {
  background: linear-gradient(135deg, #D1D5DB 0%, #E5E7EB 100%);
  color: #9CA3AF;
  box-shadow: none;
}

/* 辅助按钮 */
.btn-secondary {
  background: rgba(124, 110, 231, 0.08);
  color: #7C6EE7;
  border: 2rpx solid rgba(124, 110, 231, 0.2);
  border-radius: 48rpx;
  padding: 20rpx 48rpx;
  font-size: 28rpx;
}

.btn-secondary::after {
  border: none;
}

/* 文字样式 */
.text-muted {
  color: #9CA3AF;
  font-size: 24rpx;
}

.text-primary {
  color: #7C6EE7;
}

/* 标签 */
.tag {
  display: inline-block;
  background: linear-gradient(135deg, rgba(124, 110, 231, 0.1), rgba(167, 139, 250, 0.1));
  color: #7C6EE7;
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  margin-right: 12rpx;
}
